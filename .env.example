# Ports
API_PORT=8080
FRONTEND_PORT=5173
POSTGRES_PORT=5432
PGADMIN_PORT=5050

# Postgres (local)
POSTGRES_DB=order_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Frontend runtime (used at build time in this MVP)
VITE_API_BASE_URL=http://localhost:8080
VITE_POLLING_MS=1500

# Messaging transport
# - outbox (default): uses Postgres as a local queue (no Azure required)
# - servicebus: uses Azure Service Bus (requires connection string)
ORDER_MESSAGING_TRANSPORT=outbox

# Azure Service Bus (required only when ORDER_MESSAGING_TRANSPORT=servicebus)
# Example:
# AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=...
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=orders
