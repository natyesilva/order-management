# Portas
API_PORT=8080
FRONTEND_PORT=5173
POSTGRES_PORT=5432
PGADMIN_PORT=5050

# Postgres (local)
POSTGRES_DB=order_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Runtime do frontend (usado no build deste MVP)
VITE_API_BASE_URL=http://localhost:8080
VITE_POLLING_MS=1500

# Transporte de mensageria
# - outbox (padrão): usa o Postgres como fila local (não precisa de Azure)
# - servicebus: usa Azure Service Bus (exige connection string)
ORDER_MESSAGING_TRANSPORT=outbox

# Azure Service Bus (necessário apenas quando ORDER_MESSAGING_TRANSPORT=servicebus)
# Exemplo:
# AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=...
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=orders
