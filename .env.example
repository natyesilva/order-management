# Portas
API_PORT=8080
FRONTEND_PORT=5173
POSTGRES_PORT=5432
PGADMIN_PORT=5050
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Postgres (local)
POSTGRES_DB=order_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Runtime do frontend (usado no build deste MVP)
VITE_API_BASE_URL=http://localhost:8080
VITE_POLLING_MS=1500

# Transporte de mensageria
# - local (Docker Compose): rabbitmq
# - com Azure: servicebus
ORDER_MESSAGING_TRANSPORT=rabbitmq

# RabbitMQ (transporte de mensageria)
# Não precisa criar conta: o Docker Compose sobe o RabbitMQ localmente.
# Observação:
# - Rodando via Docker Compose: a API/worker usam o host interno `rabbitmq` (já definido no compose).
# - Rodando a API/worker direto na sua máquina (dotnet run): use `localhost`.
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_QUEUE_NAME=orders

# Azure Service Bus (quando ORDER_MESSAGING_TRANSPORT=servicebus)
AZURE_SERVICEBUS_CONNECTION_STRING=
AZURE_SERVICEBUS_QUEUE_NAME=orders

